{
  "name": "safaz-hero",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d postgres",
    "i18n:extract": "tsx scripts/extract-translation-keys.ts",
    "i18n:generate-az": "tsx scripts/generate-az-translations.ts",
    "i18n:generate-ru": "node scripts/translate-with-gcp.mjs ru",
    "i18n:generate-ar": "node scripts/translate-with-gcp.mjs ar",
    "i18n:sync": "tsx scripts/sync-i18n-seeds.ts",
    "i18n:validate": "tsx scripts/validate-i18n-coverage.ts",
    "seo:validate": "tsx scripts/seo-validate.ts",
    "seo:lighthouse": "lhci autorun",
    "i18n:seed": "cd server && npm run db:seed",
    "server:dev": "cd server && npm run dev",
    "server:install": "cd server && npm install",
    "setup:cms": "npm run db:up && npm run server:install && cd server && copy .env.example .env && npm run db:generate && npm run db:migrate && npm run admin:bootstrap && npm run content:seed"
  },
  "dependencies": {
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.98",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "ffmpeg-static": "^5.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
